layout {

    focus-ring {
        active-color   "#ffb68d"
        inactive-color "#18120f"
        urgent-color   "#ffb4ab"
    }

    border {
        active-color   "#ffb68d"
        inactive-color "#18120f"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#ffb68d"
        inactive-color "#763300"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#ffb68d80"
    }
}

recent-windows {
    highlight {
        active-color "#ffb68d"
        urgent-color "#ffb4ab"
    }
}
